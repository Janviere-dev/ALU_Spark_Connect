rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //  helpers 
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isStudent() { return userRole() == 'student'; }
    function isStartup() { return userRole() == 'startup'; }
    function adminDocIsAdmin(path) {
      return exists(path)
        && (get(path).data.get('isAdmin', false) == true
            || get(path).data.get('role', '') == 'admin');
    }
    function isAdmin() {
      return isSignedIn()
        && (adminDocIsAdmin(/databases/$(database)/documents/users/$(request.auth.uid))
            || adminDocIsAdmin(/databases/$(database)/documents/users/$(request.auth.uid + '_student')));
    }

    //  users 
    // Primary profiles live at users/{uid} (doc ID == Firebase Auth UID).
    // Secondary profiles (same email, different role) live at users/{uid}_{role};
    // they carry an authUid field pointing back to the Firebase Auth UID.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
                    || (isSignedIn()
                        && request.resource.data.authUid == request.auth.uid
                        && userId == request.auth.uid + '_' + request.resource.data.role);
      allow update: if isOwner(userId)
                    || (isSignedIn() && resource.data.authUid == request.auth.uid)
                    || (isAdmin()
                        && request.resource.data.diff(resource.data)
                            .affectedKeys().hasOnly(['status']));
      allow delete: if false;
    }

    //  opportunities 
    // Any signed-in user can read active opportunities.
    // Only the owning startup may create / update its own postings.
    // Students may increment applicantCount only (when submitting an application).
    match /opportunities/{oppId} {
      allow read: if isSignedIn();
      allow create: if isStartup()
                    && request.resource.data.startupId == request.auth.uid;
      allow update: if (isStartup() && resource.data.startupId == request.auth.uid)
                    || (isStudent()
                        && request.resource.data.diff(resource.data)
                              .affectedKeys().hasOnly(['applicantCount']));
      allow delete: if false;
    }

    //  applications 
    // Students read their own; startups read applications for their opportunities.
    // Only students can submit; only startups can update status.
    match /applications/{appId} {
      allow read: if isSignedIn()
                  && (resource.data.studentId == request.auth.uid
                      || get(/databases/$(database)/documents/opportunities/$(resource.data.opportunityId)).data.startupId == request.auth.uid);
      allow create: if isStudent()
                    && request.resource.data.studentId == request.auth.uid
                    && request.resource.data.status == 'submitted';
      allow update: if isStartup()
                    && get(/databases/$(database)/documents/opportunities/$(resource.data.opportunityId)).data.startupId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if false;
    }

    //  invitations 
    // Only the addressed student or sending startup may read an invitation.
    // Only startups can create; only the student can accept/decline (update status).
    match /invitations/{invId} {
      allow read: if isSignedIn()
                  && (resource.data.studentId == request.auth.uid
                      || resource.data.startupId == request.auth.uid);
      allow create: if isStartup()
                    && request.resource.data.startupId == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update: if isStudent()
                    && resource.data.studentId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status', 'respondedAt']);
      allow delete: if false;
    }

    //  notifications 
    // Each user reads only their own notifications.
    // Startups can write notifications to students (e.g. invitation alerts).
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
                    && (request.resource.data.userId != request.auth.uid
                        || isAdmin());
      allow update: if isSignedIn()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['isRead']);
      allow delete: if false;
    }
  }
}
